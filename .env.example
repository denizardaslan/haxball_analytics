# Haxball Analytics - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# HAXBALL CONFIGURATION
# ===========================================
# Get your token from: https://www.haxball.com/headlesstoken
HAXBALL_TOKEN=your_haxball_token_here

# Room settings (optional - defaults in code)
ROOM_NAME=Haxball Analytics Room
ROOM_MAX_PLAYERS=10
ROOM_PUBLIC=false

# ===========================================
# DATA STORAGE
# ===========================================
# Node writes JSONL here. Bruin reads this folder and builds DuckDB analytics.
DATA_DIR=./data
DUCKDB_PATH=./data/haxball_analytics.duckdb

# Live tactical map snapshot interval. Haxball runs at 60 ticks/sec.
# 15 ticks = 250ms, 30 ticks = 500ms.
SNAPSHOT_INTERVAL_TICKS=15

# ===========================================
# SERVER PORTS
# ===========================================
DEBUG_HTTP_PORT=3000

# ===========================================
# FEATURE FLAGS
# ===========================================
# Set to 'true' to enable
ENABLE_FILE_WRITER=true
ENABLE_LOCAL_BACKUP=false
ENABLE_DEBUG_DASHBOARD=true

# In-room Bruin analyst command. Players can ask questions with:
# !bruin top players
# !bruin "who is overperforming xG?"
ENABLE_BRUIN_CHAT=true
BRUIN_CHAT_COOLDOWN_MS=15000
BRUIN_CHAT_ADMIN_ONLY=false
BRUIN_ANALYST_CONNECTION=duckdb-default
BRUIN_ANALYST_LIMIT=25
BRUIN_ANALYST_TIMEOUT_MS=12000
# Optional if bruin is not available on PATH or ~/.local/bin/bruin.
# BRUIN_BIN=/absolute/path/to/bruin
